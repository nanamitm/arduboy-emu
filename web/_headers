# Cloudflare Pages headers.
#
# The emulator runs fully client-side with a single-threaded wasm module and
# postMessage-based audio, so cross-origin isolation (COOP/COEP) is NOT required.
# If you later switch to wasm threads / SharedArrayBuffer, uncomment the COOP/COEP
# block below to enable it.

# Long-cache the immutable, content-hashed build output.
/pkg/*
  Cache-Control: public, max-age=31536000, immutable

# Always revalidate the shell so updates ship immediately.
/index.html
  Cache-Control: no-cache

# /*
#   Cross-Origin-Opener-Policy: same-origin
#   Cross-Origin-Embedder-Policy: require-corp
